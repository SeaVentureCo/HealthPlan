function daysLeft() { return Math.max(0, Math.round((BERMUDA - new Date()) / 86400000)); }
function currentWeekIdx() {
  const start = new Date('2026-04-20');
  const diff = Math.floor((new Date() - start) / 86400000 / 7);
  return Math.max(0, Math.min(9, diff));
}

function makeCheckbox(checked, onclick) {
  return `<div class="checkbox${checked?' checked':''}" onclick="${onclick}"></div>`;
}

