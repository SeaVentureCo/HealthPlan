        <div style="font-size:10px;color:var(--text3);font-family:'DM Mono',monospace">SETS</div>
        <div style="font-size:10px;color:var(--text3);font-family:'DM Mono',monospace">REPS</div>
      </div>
      ${s.exercises.map(e => `
        <div style="display:grid;grid-template-columns:1fr 60px 80px;padding:10px 20px;border-top:1px solid var(--border);gap:12px;align-items:start">
          <div><div style="font-size:13px;color:var(--text);margin-bottom:2px">${e.name}</div><div style="font-size:11px;color:var(--text3)">${e.note}</div></div>
          <div style="font-family:'DM Mono',monospace;font-size:13px;color:var(--text2)">${e.sets}</div>
          <div style="font-family:'DM Mono',monospace;font-size:13px;color:var(--text2)">${e.reps}</div>
        </div>`).join('')}
    </div>`).join('');
}

function renderMeals() {
  document.getElementById('weekend-meals').innerHTML = weekendMeals.map(d => `
    <div class="meal-day" style="margin-bottom:12px">
      <div class="meal-day-header"><div class="meal-day-name">${d.day}</div><div style="font-size:11px;font-family:'DM Mono',monospace;color:var(--text3)">${d.total}</div></div>
      <div class="meal-slots">
        ${d.meals.map(m => `<div class="meal-slot"><div class="meal-slot-label">${m.slot}</div><div class="meal-slot-main">${m.food}</div><div class="meal-slot-kcal">${m.kcal}</div></div>`).join('')}
      </div>
    </div>`).join('');
}

function renderCanteen() {
  document.getElementById('canteen-days').innerHTML = canteenDays.map(d => `
    <div class="canteen-day">
      <div class="canteen-header">
        <div class="canteen-day-name">${d.day}</div>
        <span class="phase-badge phase-build">${d.training}</span>
      </div>
      <div class="canteen-verdict">${d.verdict}</div>
      <div class="canteen-picks">${d.picks.map(p => `<span class="pick pick-${p.type}">${p.label}</span>`).join('')}</div>
    </div>`).join('');
}

function renderPrep() {
  document.getElementById('prep-content').innerHTML = `
    <div class="section-title">Cooking order — Sunday afternoon</div>
    <div class="week-card" style="margin-bottom:24px">
      ${prepSteps.map((s,i) => `
        <div class="day-row" style="grid-template-columns:60px 1fr">
          <div style="font-family:'DM Mono',monospace;font-size:12px;color:var(--amber)">${s.time}</div>
          <div><div style="font-size:13px;font-weight:500;color:var(--text);margin-bottom:3px">${s.title}</div><div style="font-size:12px;color:var(--text2);line-height:1.5">${s.detail}</div></div>
        </div>`).join('')}
    </div>`;
}

function renderRules() {
  document.getElementById('rules-grid').innerHTML = dailyRules.map(r => `
    <div class="rule-card${r.accent?' rule-accent':''}">
      <div class="rule-title">${r.title}</div>
      <div class="rule-detail">${r.detail}</div>
    </div>`).join('');
}

function renderWeight() {
  const curW = currentWeekIdx();
  const grid = document.getElementById('weight-full-grid');
  grid.innerHTML = Array.from({length:11}, (_,i) => `
    <div class="weight-cell${i===curW+1?' current-week':''}">
      <div class="weight-cell-label">${i===0?'Start':'Wk '+i}</div>
      <input type="number" step="0.1" placeholder="${i===0?'90.0':'—'}" value="${state.weights[i]}" onchange="updateWeight(${i},this.value)" />
      <div class="weight-cell-sub">kg</div>
    </div>`).join('');
  renderWeightChart();
}

function renderWeightChart() {
  const projected = [90,89.1,88.1,87.0,86.0,85.0,84.0,83.0,82.1,81.2,80.5];
  const actual = state.weights.map(w => w ? parseFloat(w) : null);
  const labels = ['Start','Wk 1','Wk 2','Wk 3','Wk 4','Wk 5','Wk 6','Wk 7','Wk 8','Wk 9','Wk 10'];
  const existing = Chart.getChart('weightChart');
  if (existing) existing.destroy();
  new Chart(document.getElementById('weightChart'), {
    type: 'line',
    data: {
      labels,
      datasets: [
        {label:'Projected',data:projected,borderColor:'rgba(125,184,122,0.4)',borderDash:[5,3],pointRadius:3,pointBackgroundColor:'rgba(125,184,122,0.4)',tension:0.3,fill:false},
        {label:'Actual',data:actual,borderColor:'#7db87a',pointRadius:5,pointBackgroundColor:'#7db87a',tension:0.3,fill:false,spanGaps:false},
      ]
    },
    options: {
      responsive:true, maintainAspectRatio:false,
      plugins:{legend:{display:false},tooltip:{callbacks:{label:ctx=>ctx.dataset.label+': '+ctx.parsed.y?.toFixed(1)+'kg'}}},
      scales:{
        y:{min:78,max:91,ticks:{color:'#55534f',callback:v=>v+'kg',stepSize:2},grid:{color:'rgba(255,255,255,0.05)'}},
        x:{ticks:{color:'#55534f'},grid:{color:'rgba(255,255,255,0.05)'}}
      }
    }
  });
}

// ── ACTIONS ───────────────────────────────────────────────────────────
function toggleDay(w, d) {
  state.checked[w][d] = !state.checked[w][d];
  save();
  renderDashboard();
  renderWeekly();
}
function toggleToday(i) {
  state.today[i] = !state.today[i];
  save();
  renderDashboard();
}
function toggleSetup(i) {
  state.setup[i] = !state.setup[i];
  save();
  renderSetup();
}
function updateWeight(i, v) {
  state.weights[i] = v;
  save();
  renderWeightChart();
}
function setWeek(i) {
  activeWeek = i;
  save();
  renderWeekly();
}

// ── NAV ───────────────────────────────────────────────────────────────
function showPanel(id, navEl) {
  document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
  document.getElementById('panel-'+id).classList.add('active');
  if (navEl) navEl.classList.add('active');
  if (id==='weight') renderWeight();
}

// ── INIT ──────────────────────────────────────────────────────────────
renderDashboard();
renderSetup();
renderCheckpoints();
renderWeekly();
renderWorkouts();
renderMeals();
renderCanteen();
renderPrep();
renderRules();
</script>
</body>
</html>