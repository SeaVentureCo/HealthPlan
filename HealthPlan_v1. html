<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Blair — Bermuda Cut</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=Syne:wght@400;500;600;700&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0e0f0e;
    --bg2: #151614;
    --bg3: #1c1e1b;
    --border: rgba(255,255,255,0.07);
    --border2: rgba(255,255,255,0.12);
    --text: #f0ede8;
    --text2: #8a8880;
    --text3: #55534f;
    --green: #7db87a;
    --green-bg: rgba(125,184,122,0.1);
    --green-border: rgba(125,184,122,0.25);
    --amber: #d4a84b;
    --amber-bg: rgba(212,168,75,0.1);
    --blue: #6a9fd8;
    --blue-bg: rgba(106,159,216,0.1);
    --coral: #d47a5a;
    --coral-bg: rgba(212,122,90,0.1);
    --purple: #9b87cc;
    --purple-bg: rgba(155,135,204,0.1);
    --pink: #c47a9a;
    --pink-bg: rgba(196,122,154,0.1);
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { background: var(--bg); color: var(--text); font-family: 'DM Sans', sans-serif; font-size: 14px; min-height: 100vh; }
  
  /* Layout */
  .app { display: grid; grid-template-columns: 220px 1fr; min-height: 100vh; }
  .sidebar { background: var(--bg2); border-right: 1px solid var(--border); padding: 28px 0; display: flex; flex-direction: column; position: sticky; top: 0; height: 100vh; overflow-y: auto; }
  .main { padding: 36px 40px; overflow-y: auto; }

  /* Sidebar */
  .sidebar-logo { padding: 0 24px 28px; border-bottom: 1px solid var(--border); margin-bottom: 16px; }
  .sidebar-logo-main { font-family: 'Syne', sans-serif; font-size: 15px; font-weight: 700; color: var(--text); letter-spacing: -0.02em; }
  .sidebar-logo-sub { font-size: 11px; color: var(--text3); margin-top: 2px; font-family: 'DM Mono', monospace; }
  .sidebar-section { padding: 8px 24px 4px; font-size: 9px; font-weight: 600; color: var(--text3); letter-spacing: .12em; text-transform: uppercase; font-family: 'DM Mono', monospace; margin-top: 8px; }
  .nav-item { display: flex; align-items: center; gap: 10px; padding: 9px 24px; cursor: pointer; border-left: 2px solid transparent; transition: all .15s; color: var(--text2); font-size: 13px; }
  .nav-item:hover { color: var(--text); background: var(--bg3); }
  .nav-item.active { color: var(--text); border-left-color: var(--green); background: var(--green-bg); }
  .nav-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--text3); flex-shrink: 0; }
  .nav-item.active .nav-dot { background: var(--green); }
  .nav-item.done .nav-dot { background: var(--green); }
  .nav-item.done { color: var(--text2); }
  .sidebar-footer { margin-top: auto; padding: 20px 24px 0; border-top: 1px solid var(--border); }
  .days-chip { background: var(--amber-bg); border: 1px solid rgba(212,168,75,0.2); border-radius: 8px; padding: 10px 12px; }
  .days-num { font-family: 'Syne', sans-serif; font-size: 28px; font-weight: 700; color: var(--amber); }
  .days-label { font-size: 11px; color: var(--text2); margin-top: 1px; }

  /* Panels */
  .panel { display: none; }
  .panel.active { display: block; }

  /* Page header */
  .page-header { margin-bottom: 32px; }
  .page-title { font-family: 'Syne', sans-serif; font-size: 26px; font-weight: 700; color: var(--text); letter-spacing: -0.03em; }
  .page-sub { font-size: 13px; color: var(--text2); margin-top: 6px; }

  /* Stats row */
  .stats-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; margin-bottom: 28px; }
  .stat-card { background: var(--bg2); border: 1px solid var(--border); border-radius: 12px; padding: 16px 18px; }
  .stat-label { font-size: 10px; color: var(--text3); text-transform: uppercase; letter-spacing: .08em; font-family: 'DM Mono', monospace; margin-bottom: 8px; }
  .stat-value { font-family: 'Syne', sans-serif; font-size: 24px; font-weight: 700; color: var(--text); letter-spacing: -0.02em; }
  .stat-sub { font-size: 11px; color: var(--text3); margin-top: 3px; }

  /* Progress bar */
  .prog-wrap { background: var(--bg2); border: 1px solid var(--border); border-radius: 12px; padding: 18px 20px; margin-bottom: 28px; }
  .prog-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; }
  .prog-title { font-size: 12px; font-weight: 500; color: var(--text2); }
  .prog-pct { font-family: 'DM Mono', monospace; font-size: 13px; color: var(--green); }
  .prog-track { height: 4px; background: var(--bg3); border-radius: 2px; overflow: hidden; }
  .prog-fill { height: 100%; background: var(--green); border-radius: 2px; transition: width .4s ease; }

  /* Week nav */
  .week-nav { display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 20px; }
  .week-btn { font-family: 'DM Mono', monospace; font-size: 11px; padding: 6px 14px; border-radius: 6px; border: 1px solid var(--border); background: transparent; color: var(--text2); cursor: pointer; transition: all .15s; }
  .week-btn:hover { border-color: var(--border2); color: var(--text); }
  .week-btn.active { background: var(--green-bg); border-color: var(--green-border); color: var(--green); }
  .week-btn.done { border-color: rgba(125,184,122,0.15); color: var(--green); opacity: 0.6; }

  /* Phase badge */
  .phase-badge { display: inline-block; font-size: 10px; font-family: 'DM Mono', monospace; padding: 3px 10px; border-radius: 4px; }
  .phase-reset { background: var(--blue-bg); color: var(--blue); }
  .phase-build { background: var(--green-bg); color: var(--green); }
  .phase-push { background: var(--coral-bg); color: var(--coral); }
  .phase-peak { background: var(--amber-bg); color: var(--amber); }
  .phase-arrive { background: var(--purple-bg); color: var(--purple); }

  /* Day table */
  .week-card { background: var(--bg2); border: 1px solid var(--border); border-radius: 12px; overflow: hidden; margin-bottom: 24px; }
  .week-card-header { padding: 14px 20px; border-bottom: 1px solid var(--border); display: flex; align-items: center; justify-content: space-between; }
  .week-card-title { font-family: 'Syne', sans-serif; font-size: 14px; font-weight: 600; }
  .day-row { display: grid; grid-template-columns: 90px 120px 1fr 36px; align-items: center; gap: 16px; padding: 13px 20px; border-bottom: 1px solid var(--border); transition: background .1s; }
  .day-row:last-child { border-bottom: none; }
  .day-row:hover { background: var(--bg3); }
  .day-row.completed { opacity: 0.45; }
  .day-name { font-size: 13px; font-weight: 500; color: var(--text); }
  .day-tag { font-size: 10px; font-family: 'DM Mono', monospace; padding: 3px 9px; border-radius: 4px; display: inline-block; }
  .tag-strength { background: var(--blue-bg); color: var(--blue); }
  .tag-zone2 { background: var(--green-bg); color: var(--green); }
  .tag-hiit { background: var(--coral-bg); color: var(--coral); }
  .tag-yoga { background: var(--purple-bg); color: var(--purple); }
  .tag-social { background: var(--pink-bg); color: var(--pink); }
  .tag-rest { background: rgba(138,136,128,0.1); color: var(--text2); }
  .tag-travel { background: var(--amber-bg); color: var(--amber); }
  .day-detail { font-size: 12px; color: var(--text2); line-height: 1.5; }
  .checkbox { width: 20px; height: 20px; border-radius: 5px; border: 1.5px solid var(--border2); background: transparent; cursor: pointer; display: flex; align-items: center; justify-content: center; flex-shrink: 0; transition: all .15s; }
  .checkbox:hover { border-color: var(--green); }
  .checkbox.checked { background: var(--green); border-color: var(--green); }
  .checkbox.checked::after { content: ''; display: block; width: 5px; height: 9px; border: 2px solid #0e0f0e; border-top: none; border-left: none; transform: rotate(45deg) translate(-1px, -2px); }

  /* Weight log */
  .section-title { font-family: 'Syne', sans-serif; font-size: 13px; font-weight: 600; color: var(--text); margin-bottom: 14px; }
  .weight-grid { display: grid; grid-template-columns: repeat(6, 1fr); gap: 8px; margin-bottom: 28px; }
  .weight-cell { background: var(--bg2); border: 1px solid var(--border); border-radius: 10px; padding: 12px; text-align: center; }
  .weight-cell.current-week { border-color: var(--amber); }
  .weight-cell-label { font-size: 10px; color: var(--text3); font-family: 'DM Mono', monospace; margin-bottom: 8px; }
  .weight-cell input { width: 100%; background: transparent; border: none; outline: none; text-align: center; font-size: 16px; font-weight: 500; font-family: 'Syne', sans-serif; color: var(--text); }
  .weight-cell input::placeholder { color: var(--text3); font-size: 13px; }
  .weight-cell-sub { font-size: 10px; color: var(--text3); margin-top: 4px; }

  /* Checklist */
  .checklist { display: flex; flex-direction: column; gap: 6px; margin-bottom: 28px; }
  .check-item { display: flex; align-items: center; gap: 12px; padding: 12px 16px; background: var(--bg2); border: 1px solid var(--border); border-radius: 10px; cursor: pointer; transition: background .1s; }
  .check-item:hover { background: var(--bg3); }
  .check-item.checked-item { opacity: 0.5; }
  .check-text { font-size: 13px; color: var(--text); flex: 1; }
  .check-sub { font-size: 11px; color: var(--text2); margin-top: 2px; }
  .check-item.checked-item .check-text { text-decoration: line-through; color: var(--text2); }

  /* Checkpoints */
  .checkpoints-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 28px; }
  .cp-card { background: var(--bg2); border: 1px solid var(--border); border-radius: 10px; padding: 14px 16px; }
  .cp-card.now { border-color: var(--coral); background: var(--coral-bg); }
  .cp-week-label { font-size: 10px; font-family: 'DM Mono', monospace; margin-bottom: 5px; }
  .cp-card.now .cp-week-label { color: var(--coral); }
  .cp-card:not(.now) .cp-week-label { color: var(--text3); }
  .cp-title { font-size: 13px; font-weight: 500; color: var(--text); margin-bottom: 4px; }
  .cp-detail { font-size: 11px; color: var(--text2); line-height: 1.6; }
  .cp-btn { margin-top: 10px; background: transparent; border: 1px solid var(--border2); border-radius: 6px; padding: 6px 12px; font-size: 11px; color: var(--text2); cursor: pointer; font-family: 'DM Sans', sans-serif; transition: all .15s; }
  .cp-btn:hover { color: var(--text); border-color: var(--text2); }

  /* Daily rules */
  .rules-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-bottom: 28px; }
  .rule-card { background: var(--bg2); border: 1px solid var(--border); border-radius: 10px; padding: 14px 16px; }
  .rule-title { font-size: 12px; font-weight: 500; color: var(--text); margin-bottom: 3px; }
  .rule-detail { font-size: 11px; color: var(--text2); line-height: 1.5; }
  .rule-accent { border-left: 2px solid var(--green); padding-left: 12px; border-radius: 0 10px 10px 0; }

  /* Meals panel */
  .meal-day { background: var(--bg2); border: 1px solid var(--border); border-radius: 12px; overflow: hidden; margin-bottom: 12px; }
  .meal-day-header { padding: 12px 18px; border-bottom: 1px solid var(--border); display: flex; justify-content: space-between; align-items: center; }
  .meal-day-name { font-size: 13px; font-weight: 500; }
  .meal-slots { display: grid; grid-template-columns: repeat(3, 1fr); }
  .meal-slot { padding: 12px 18px; border-right: 1px solid var(--border); }
  .meal-slot:last-child { border-right: none; }
  .meal-slot-label { font-size: 9px; color: var(--text3); text-transform: uppercase; letter-spacing: .1em; font-family: 'DM Mono', monospace; margin-bottom: 5px; }
  .meal-slot-main { font-size: 12px; color: var(--text); line-height: 1.4; }
  .meal-slot-kcal { font-size: 10px; color: var(--text3); margin-top: 4px; font-family: 'DM Mono', monospace; }

  /* Canteen */
  .canteen-day { background: var(--bg2); border: 1px solid var(--border); border-radius: 12px; overflow: hidden; margin-bottom: 10px; }
  .canteen-header { padding: 12px 18px; border-bottom: 1px solid var(--border); display: flex; justify-content: space-between; }
  .canteen-day-name { font-size: 13px; font-weight: 500; }
  .canteen-verdict { font-size: 12px; color: var(--text2); padding: 10px 18px 6px; line-height: 1.5; }
  .canteen-picks { padding: 6px 18px 12px; display: flex; flex-wrap: wrap; gap: 5px; }
  .pick { font-size: 11px; padding: 3px 9px; border-radius: 4px; }
  .pick-yes { background: var(--green-bg); color: var(--green); border: 1px solid var(--green-border); }
  .pick-no { background: rgba(212,122,90,0.1); color: var(--coral); border: 1px solid rgba(212,122,90,0.2); }
  .pick-ok { background: var(--amber-bg); color: var(--amber); border: 1px solid rgba(212,168,75,0.2); }

  /* Scrollbar */
  ::-webkit-scrollbar { width: 4px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: var(--border2); border-radius: 2px; }

  /* Responsive */
  @media (max-width: 900px) {
    .app { grid-template-columns: 1fr; }
    .sidebar { position: static; height: auto; }
    .stats-row { grid-template-columns: 1fr 1fr; }
    .weight-grid { grid-template-columns: repeat(4, 1fr); }
    .checkpoints-grid { grid-template-columns: 1fr; }
  }
</style>
</head>
<body>
<div class="app">

<!-- SIDEBAR -->
<aside class="sidebar">
  <div class="sidebar-logo">
    <div class="sidebar-logo-main">Blair — Bermuda Cut</div>
    <div class="sidebar-logo-sub">9 July 2026 · 10 weeks</div>
  </div>

  <div class="sidebar-section">Overview</div>
  <div class="nav-item active" onclick="showPanel('dashboard',this)"><div class="nav-dot"></div>Dashboard</div>
  <div class="nav-item" onclick="showPanel('setup',this)"><div class="nav-dot"></div>Setup checklist</div>
  <div class="nav-item" onclick="showPanel('checkpoints',this)"><div class="nav-dot"></div>Plan checkpoints</div>

  <div class="sidebar-section">Training</div>
  <div class="nav-item" onclick="showPanel('weekly',this)"><div class="nav-dot"></div>Weekly schedule</div>
  <div class="nav-item" onclick="showPanel('workouts',this)"><div class="nav-dot"></div>Workout detail</div>

  <div class="sidebar-section">Nutrition</div>
  <div class="nav-item" onclick="showPanel('meals',this)"><div class="nav-dot"></div>Meal plan</div>
  <div class="nav-item" onclick="showPanel('canteen',this)"><div class="nav-dot"></div>Canteen guide</div>
  <div class="nav-item" onclick="showPanel('prep',this)"><div class="nav-dot"></div>Sunday prep</div>

  <div class="sidebar-section">Daily</div>
  <div class="nav-item" onclick="showPanel('rules',this)"><div class="nav-dot"></div>Non-negotiables</div>
  <div class="nav-item" onclick="showPanel('weight',this)"><div class="nav-dot"></div>Weight log</div>

  <div class="sidebar-footer">
    <div class="days-chip">
      <div class="days-num" id="sidebar-days">81</div>
      <div class="days-label">days to Bermuda</div>
    </div>
  </div>
</aside>

<!-- MAIN -->
<main class="main">

<!-- DASHBOARD -->
<div class="panel active" id="panel-dashboard">
  <div class="page-header">
    <div class="page-title">Dashboard</div>
    <div class="page-sub">Your 10-week Bermuda cut — starting 20 April 2026</div>
  </div>
  <div class="stats-row">
    <div class="stat-card"><div class="stat-label">Start weight</div><div class="stat-value">90kg</div><div class="stat-sub">198.4 lbs</div></div>
    <div class="stat-card"><div class="stat-label">Current week</div><div class="stat-value" id="dash-week">Week 1</div><div class="stat-sub" id="dash-phase">Reset phase</div></div>
    <div class="stat-card"><div class="stat-label">Days to Bermuda</div><div class="stat-value" id="dash-days">81</div><div class="stat-sub">9 July 2026</div></div>
    <div class="stat-card"><div class="stat-label">Target</div><div class="stat-value">80–83kg</div><div class="stat-sub">176–183 lbs</div></div>
  </div>
  <div class="prog-wrap">
    <div class="prog-header"><span class="prog-title">10-week progress</span><span class="prog-pct" id="dash-overall-pct">0%</span></div>
    <div class="prog-track"><div class="prog-fill" id="dash-overall-bar" style="width:0%"></div></div>
  </div>
  <div class="section-title">This week at a glance</div>
  <div class="week-card" id="dash-week-card"></div>
  <div class="section-title" style="margin-top:24px">Today's non-negotiables</div>
  <div class="checklist" id="dash-today"></div>
</div>

<!-- SETUP -->
<div class="panel" id="panel-setup">
  <div class="page-header">
    <div class="page-title">Setup checklist</div>
    <div class="page-sub">Do these before Sunday 20 April — your plan starts here</div>
  </div>
  <div class="checklist" id="setup-list"></div>
</div>

<!-- CHECKPOINTS -->
<div class="panel" id="panel-checkpoints">
  <div class="page-header">
    <div class="page-title">Plan checkpoints</div>
    <div class="page-sub">When to come back to Claude and what to ask for</div>
  </div>
  <div class="checkpoints-grid" id="cp-grid"></div>
</div>

<!-- WEEKLY -->
<div class="panel" id="panel-weekly">
  <div class="page-header">
    <div class="page-title">Weekly schedule</div>
    <div class="page-sub">Tick off each session as you complete it</div>
  </div>
  <div class="week-nav" id="week-nav"></div>
  <div class="prog-wrap">
    <div class="prog-header"><span class="prog-title" id="week-prog-label">Week 1 progress</span><span class="prog-pct" id="week-prog-pct">0%</span></div>
    <div class="prog-track"><div class="prog-fill" id="week-prog-fill" style="width:0%"></div></div>
  </div>
  <div class="week-card" id="week-detail-card"></div>
</div>

<!-- WORKOUTS -->
<div class="panel" id="panel-workouts">
  <div class="page-header">
    <div class="page-title">Workout detail</div>
    <div class="page-sub">Exercises, sets and reps for each strength session</div>
  </div>
  <div id="workout-cards"></div>
</div>

<!-- MEALS -->
<div class="panel" id="panel-meals">
  <div class="page-header">
    <div class="page-title">Meal plan</div>
    <div class="page-sub">Daily food structure — smoothie, canteen, prepped dinner</div>
  </div>
  <div style="background:var(--bg2);border:1px solid var(--border);border-radius:12px;padding:18px 20px;margin-bottom:20px">
    <div class="section-title" style="margin-bottom:12px">Daily structure — every weekday</div>
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:10px">
      <div style="border-right:1px solid var(--border);padding-right:16px"><div style="font-size:10px;color:var(--text3);font-family:'DM Mono',monospace;margin-bottom:6px">BREAKFAST · HOME</div><div style="font-size:13px;color:var(--text);margin-bottom:4px">Protein smoothie</div><div style="font-size:11px;color:var(--text2);line-height:1.5">2 scoops whey · frozen spinach · frozen berries · ½ banana · almond milk · 1 tbsp nut butter</div><div style="font-size:10px;color:var(--text3);margin-top:6px;font-family:'DM Mono',monospace">~500 kcal · 52g protein</div></div>
      <div style="border-right:1px solid var(--border);padding:0 16px"><div style="font-size:10px;color:var(--text3);font-family:'DM Mono',monospace;margin-bottom:6px">LUNCH · UBER CANTEEN</div><div style="font-size:13px;color:var(--text);margin-bottom:4px">Biggest meal of the day</div><div style="font-size:11px;color:var(--text2);line-height:1.5">Protein + veg first. Small carbs. Skip dessert, 3pm snacks and canteen smoothies always.</div><div style="font-size:10px;color:var(--text3);margin-top:6px;font-family:'DM Mono',monospace">~650 kcal · 55g protein</div></div>
      <div style="padding-left:16px"><div style="font-size:10px;color:var(--text3);font-family:'DM Mono',monospace;margin-bottom:6px">DINNER · HOME (PREPPED)</div><div style="font-size:13px;color:var(--text);margin-bottom:4px">Pull from the fridge</div><div style="font-size:11px;color:var(--text2);line-height:1.5">Already made Sunday. Heat and eat within 10 min of getting home. No Uber Eats.</div><div style="font-size:10px;color:var(--text3);margin-top:6px;font-family:'DM Mono',monospace">~470 kcal · 50g protein</div></div>
    </div>
  </div>
  <div class="section-title">Weekend meals</div>
  <div id="weekend-meals"></div>
</div>

<!-- CANTEEN -->
<div class="panel" id="panel-canteen">
  <div class="page-header">
    <div class="page-title">Canteen guide</div>
    <div class="page-sub">This week's Uber Amsterdam menu — best choices highlighted</div>
  </div>
  <div id="canteen-days"></div>
</div>

<!-- PREP -->
<div class="panel" id="panel-prep">
  <div class="page-header">
    <div class="page-title">Sunday meal prep</div>
    <div class="page-sub">9 meals in ~2 hours — covers all weeknight dinners + weekend lunch & dinner</div>
  </div>
  <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:24px">
    <div class="stat-card"><div class="stat-label">Meals prepped</div><div class="stat-value">9</div><div class="stat-sub">All dinners + wknd lunch</div></div>
    <div class="stat-card"><div class="stat-label">Prep time</div><div class="stat-value">~2 hrs</div><div class="stat-sub">After yoga</div></div>
    <div class="stat-card"><div class="stat-label">Containers</div><div class="stat-value">9</div><div class="stat-sub">MCIRCO 10-set covers it</div></div>
    <div class="stat-card"><div class="stat-label">Est. cost</div><div class="stat-value">€28–35</div><div class="stat-sub">Albert Heijn or Jumbo</div></div>
  </div>
  <div id="prep-content"></div>
</div>

<!-- RULES -->
<div class="panel" id="panel-rules">
  <div class="page-header">
    <div class="page-title">Non-negotiables</div>
    <div class="page-sub">Every single day — these are the plan</div>
  </div>
  <div class="rules-grid" id="rules-grid"></div>
  <div class="section-title">Sleep protocol</div>
