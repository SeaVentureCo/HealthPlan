function renderDayCard(weekIdx, container) {
  const w = weeks[weekIdx];
  let html = `<div class="week-card-header"><div class="week-card-title">${w.label} · ${w.dates}</div><span class="phase-badge ${w.phaseClass}">${w.phase}</span></div>`;
  w.days.forEach((d,i) => {
    const done = state.checked[weekIdx][i];
    html += `<div class="day-row${done?' completed':''}">
      <div class="day-name">${d.name}</div>
      <div><span class="day-tag ${tagMap[d.tag]}">${tagLabel[d.tag]}</span></div>
      <div class="day-detail">${d.detail}</div>
      ${makeCheckbox(done, `toggleDay(${weekIdx},${i})`)}
    </div>`;
  });
  container.innerHTML = html;
}

function renderWeekProgress(weekIdx) {
  const done = state.checked[weekIdx].filter(Boolean).length;
  const pct = Math.round(done / 7 * 100);
  return {done, pct};
}

function renderOverallProgress() {
  let total = 0;
  state.checked.forEach(w => w.forEach(d => { if(d) total++; }));
  return Math.round(total / 70 * 100);
}

